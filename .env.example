# Server
PORT=8080
TIMEOUT=30m

# TLS (선택사항)
# TLS_CERT=./scripts/cert.pem
# TLS_KEY=./scripts/key.pem

# Auth: none | key | hash
AUTH_MODE=none
# AUTH_KEY=your-secret-key
# AUTH_SECRET=your-hmac-secret
# AUTH_WINDOW=30

# Whitelist (쉼표로 구분, 와일드카드 지원)
# WHITELIST=api.example.com,*.example.org

# Custom headers
HEADER_URL=Yumi-Url
HEADER_PREFIX=Yumi-H-
HEADER_BULK=Yumi-Headers
HEADER_BODY_TRANSFORM=Yumi-Body-Transform
HEADER_AUTH=Yumi-Auth
