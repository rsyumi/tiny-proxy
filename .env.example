# Server
PORT=8080
TIMEOUT=30s   # upstream response header timeout (e.g. 30s, 2m, 10m)

# Auth: "none" | "key" | "hash"
AUTH_MODE=key
AUTH_KEY=my-secret-key
# AUTH_SECRET=my-hmac-secret  # for hash mode
# AUTH_WINDOW=30              # hash window size in seconds

# Whitelist (comma-separated hostnames, empty = allow all)
WHITELIST=api.example.com,cdn.example.com

# Custom header names
HEADER_URL=X-Proxy-Url
HEADER_PREFIX=X-Proxy-H-
HEADER_BULK=X-Proxy-Headers
HEADER_AUTH=X-Proxy-Auth
